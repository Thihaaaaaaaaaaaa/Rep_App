# ───────────────────────────────────────────────────────────
#  Copy this file to ".env" and fill in your values.
#  Find these in: Supabase Dashboard → Project Settings → API
#  NEVER commit .env, and NEVER put the service_role key in the
#  frontend — it bypasses all security and lives ONLY here.
# ───────────────────────────────────────────────────────────

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

PORT=3000
NODE_ENV=development

# Comma-separated emails allowed into the admin panel (/admin.html).
# These accounts can ban people and read logs. Sign up in the app with
# one of these emails first.
ADMIN_EMAILS=you@example.com
